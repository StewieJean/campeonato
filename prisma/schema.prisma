// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int     @id @default(autoincrement())
  nombres           String
  apellido_paterno  String
  apellido_materno  String
  dni               String  @unique
  celular           String
  email             String  @unique

  team              Team?
}

model Admin {
  id           Int    @id @default(autoincrement())
  organizador  String
  correo       String @unique
  nro_celular  String
  dni          String @unique
  password     String
}

model ProfessionalCollege {
  id          Int    @id @default(autoincrement())
  nombre      String @unique
  abreviatura String? @unique

  teams       Team[]
}

model Category {
  id          Int    @id @default(autoincrement())
  nombre      String @unique

  teams       Team[]
  matches     Match[]
}

model Team {
  id                     Int                 @id @default(autoincrement())
  nombre                 String
  categoria              String?
  userId                 Int                 @unique
  categoryId             Int?
  professionalCollegeId  Int?
  playerRegistrationToken String?
  playerRegistrationTokenExpiresAt DateTime?
  registrationClosed     Boolean             @default(false)

  user                   User                @relation(fields: [userId], references: [id])
  category               Category?           @relation(fields: [categoryId], references: [id])
  professionalCollege    ProfessionalCollege? @relation(fields: [professionalCollegeId], references: [id])

  players                Player[]
  homeMatches            Match[]             @relation("HomeMatches")
  awayMatches            Match[]             @relation("AwayMatches")
  matchEvents            MatchEvent[]
}

model Player {
  id                Int     @id @default(autoincrement())
  nombres           String  @default("")
  apellido_paterno  String  @default("")
  apellido_materno  String  @default("")
  dni               String  @unique
  nro_colegiatura   String?
  fecha_nacimiento  DateTime? @db.Date
  foto_url          String?
  codigo_carnet     String? @unique
  carnet_activo     Boolean @default(true)

  teamId            Int
  team              Team    @relation(fields: [teamId], references: [id])

  matchEvents       MatchEvent[]
}

model Match {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  jornada     Int
  fecha       DateTime?
  cancha      String?
  homeTeamId  Int
  awayTeamId  Int
  homeGoals   Int?
  awayGoals   Int?
  estado      String    @default("PROGRAMADO")

  category    Category    @relation(fields: [categoryId], references: [id])
  homeTeam    Team        @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam    Team        @relation("AwayMatches", fields: [awayTeamId], references: [id])
  events      MatchEvent[]

  @@index([categoryId, jornada])
}

model MatchEvent {
  id        Int     @id @default(autoincrement())
  matchId   Int
  playerId  Int
  teamId    Int
  tipo      String
  minuto    Int?

  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player  @relation(fields: [playerId], references: [id])
  team      Team    @relation(fields: [teamId], references: [id])

  @@index([matchId])
  @@index([playerId, tipo])
}
